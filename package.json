{
  "name": "luojia-math-tutor-init",
  "version": "1.0.0",
  "description": "珞珈数智助教 - 全平台数学 AI 助教初始化工具",
  "main": "bin/init.js",
  "bin": {
    "luojia-math-init": "bin/init.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "luojia-math-tutor/SKILL.md",
    "luojia-math-tutor/agents/",
    "luojia-math-tutor/references/*.md",
    "luojia-math-tutor/references/output/*.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node scripts/validate-json.js && node scripts/run-api-tests.js && npm.cmd run test:web:ui",
    "test:knowledge": "node scripts/validate-json.js",
    "test:api": "node scripts/run-api-tests.js",
    "test:web:ui": "cd apps/web && node --experimental-strip-types --test lib/ui-runtime.test.ts",
    "dev:api": "cd apps/api && python -m uvicorn app.main:app --reload --port 8000",
    "dev:web": "cd apps/web && npm.cmd run dev",
    "build:web": "cd apps/web && npm.cmd run build",
    "test:web": "cd apps/web && npm.cmd run build"
  },
  "keywords": [
    "math",
    "ai",
    "claude",
    "cursor",
    "gemini"
  ],
  "author": "Luojia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leionel/luojia-math-tutor-skill.git"
  },
  "bugs": {
    "url": "https://github.com/Leionel/luojia-math-tutor-skill/issues"
  },
  "homepage": "https://github.com/Leionel/luojia-math-tutor-skill#readme",
  "license": "MIT"
}
